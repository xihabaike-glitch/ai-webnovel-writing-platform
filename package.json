{
  "name": "ai-webnovel-writing-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "test": "node scripts/run-tests.mjs",
    "test:migrations": "node --import tsx --test scripts/migrations.test.ts",
    "test:compose-config": "node scripts/test-compose-config.mjs",
    "lint": "eslint .",
    "check": "npm run prisma:generate && npm run prisma:validate && npm run lint && npm run test && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:validate": "node scripts/prisma-validate.mjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:deploy": "prisma migrate deploy",
    "db:baseline": "node scripts/baseline-database.mjs",
    "db:seed": "npm run db:deploy && npm run prisma:seed",
    "env:ensure-secret": "node scripts/ensure-model-credential-secret.mjs",
    "setup": "node scripts/setup.mjs",
    "local:start": "node scripts/start.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "^15.5.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
