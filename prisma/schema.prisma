generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id               String   @id @default(cuid())
  title            String
  targetPlatform   String
  targetLengthType String
  targetWordCount  Int
  currentWordCount Int      @default(0)
  genre            String
  sellingPoint     String   @default("")
  updateCadence    String   @default("")
  aiMonthlyBudgetUsd      Float    @default(5)
  aiMaxTaskCostUsd        Float    @default(0.25)
  aiMaxBatchCostUsd       Float    @default(1)
  aiMaxFailureRatePercent Int      @default(20)
  aiBudgetEnforcement     String   @default("block")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  chapters         Chapter[]
  characters       Character[]
  worldEntries     WorldEntry[]
  foreshadows      Foreshadow[]
  plotThreads      PlotThread[]
  outlineNodes     OutlineNode[]
  aiTasks          AiTask[]
  publishSnapshots PublishPackageSnapshot[]
  submissionAssets PlatformSubmissionAsset[]
  submissionAssetVersions PlatformSubmissionAssetVersion[]
  platformPublishMetrics PlatformPublishMetric[]
  gateActionAudits GateActionAudit[]
  gateDispatchTasks GateDispatchTask[]
  platformKnowledgeFeedbackReceipts PlatformKnowledgeFeedbackReceipt[]
  exportPackageSnapshots ExportPackageSnapshot[]
}

model Chapter {
  id          String   @id @default(cuid())
  projectId   String
  volumeId    String?
  order       Int
  title       String
  content     String   @default("")
  wordCount   Int      @default(0)
  goal        String   @default("")
  hook        String   @default("")
  conflict    String   @default("")
  valueShift  String   @default("")
  cliffhanger String   @default("")
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  outlineNodes OutlineNode[]
  revisions    ChapterRevision[]
}

model ChapterRevision {
  id           String   @id @default(cuid())
  chapterId    String
  source       String
  sourceTaskId String?
  title        String
  content      String   @default("")
  wordCount    Int      @default(0)
  goal         String   @default("")
  hook         String   @default("")
  conflict     String   @default("")
  valueShift   String   @default("")
  cliffhanger  String   @default("")
  status       String
  notes        String   @default("")
  createdAt    DateTime @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model OutlineNode {
  id           String   @id @default(cuid())
  projectId    String
  parentId     String?
  chapterId    String?
  type         String
  title        String
  summary      String   @default("")
  goal         String   @default("")
  hook         String   @default("")
  conflict     String   @default("")
  valueShift   String   @default("")
  platformNote String   @default("")
  order        Int      @default(0)
  depth        Int      @default(0)
  status       String   @default("planned")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter  Chapter?      @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  parent   OutlineNode?  @relation("OutlineTree", fields: [parentId], references: [id], onDelete: Cascade)
  children OutlineNode[] @relation("OutlineTree")
}

model Character {
  id                String   @id @default(cuid())
  projectId         String
  name              String
  role              String
  desire            String   @default("")
  need              String   @default("")
  flaw              String   @default("")
  arcStart          String   @default("")
  arcEnd            String   @default("")
  voice             String   @default("")
  relationshipNotes String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model WorldEntry {
  id        String   @id @default(cuid())
  projectId String
  type      String
  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Foreshadow {
  id                  String   @id @default(cuid())
  projectId           String
  title               String
  setupChapterId      String?
  payoffChapterId     String?
  relatedCharacterIds String   @default("[]")
  status              String   @default("planned")
  notes               String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PlotThread {
  id             String   @id @default(cuid())
  projectId      String
  type           String
  title          String
  startChapterId String?
  endChapterId   String?
  status         String   @default("planned")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ModelProvider {
  id               String   @id @default(cuid())
  providerId       String
  displayName      String
  baseUrl          String?
  encryptedApiKey  String?
  defaultModel     String
  enabled          Boolean  @default(true)
  maxContextTokens Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  aiTasks        AiTask[]
  primaryRoutes  ModelTaskRoute[] @relation("PrimaryRouteProvider")
  fallbackRoutes ModelTaskRoute[] @relation("FallbackRouteProvider")
}

model ModelTaskRoute {
  id                       String   @id @default(cuid())
  taskType                 String   @unique
  primaryProviderConfigId  String?
  fallbackProviderConfigId String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  primaryProvider  ModelProvider? @relation("PrimaryRouteProvider", fields: [primaryProviderConfigId], references: [id], onDelete: SetNull)
  fallbackProvider ModelProvider? @relation("FallbackRouteProvider", fields: [fallbackProviderConfigId], references: [id], onDelete: SetNull)
}

model ModelRouteAvoidanceOverride {
  id        String   @id @default(cuid())
  ruleKey   String   @unique
  action    String
  taskType  String?
  note      String   @default("")
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiTask {
  id               String   @id @default(cuid())
  projectId        String
  chapterId        String?
  taskType         String
  providerConfigId String
  model            String
  status           String   @default("queued")
  inputSnapshot    String
  outputText       String?
  inputTokens      Int?
  outputTokens     Int?
  costUsd          Float?
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  modelProvider ModelProvider @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
}

model PublishPackageSnapshot {
  id             String   @id @default(cuid())
  projectId      String
  platformId     String
  platformName   String
  title          String
  logline        String
  synopsis       String
  tags           String   @default("[]")
  markdown       String
  chapterCount   Int      @default(0)
  wordCount      Int      @default(0)
  preflightScore Int      @default(0)
  canExport      Boolean  @default(false)
  action         String
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ExportPackageSnapshot {
  id               String   @id @default(cuid())
  projectId        String
  packageKind      String
  format           String
  title            String
  fileName         String
  contentType      String
  fileSize         Int      @default(0)
  contentHash      String
  readinessStatus  String
  readinessPercent Int      @default(0)
  chapterCount     Int      @default(0)
  wordCount        Int      @default(0)
  notes            String   @default("")
  createdAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([projectId, packageKind, format, createdAt])
}

model PlatformSubmissionAsset {
  id               String   @id @default(cuid())
  projectId        String
  platformId       String
  platformName     String
  title            String
  logline          String
  synopsis         String
  overseasSynopsis String   @default("")
  tags             String   @default("[]")
  note             String   @default("")
  source           String   @default("manual")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project  Project                          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions PlatformSubmissionAssetVersion[]

  @@unique([projectId, platformId])
}

model PlatformSubmissionAssetVersion {
  id               String   @id @default(cuid())
  projectId        String
  assetId          String?
  platformId       String
  platformName     String
  title            String
  logline          String
  synopsis         String
  overseasSynopsis String   @default("")
  tags             String   @default("[]")
  note             String   @default("")
  source           String   @default("manual")
  sourceTaskId     String?
  strategy         String   @default("")
  auditScore       Int      @default(0)
  auditStatus      String   @default("needs_work")
  action           String
  createdAt        DateTime @default(now())

  project Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   PlatformSubmissionAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([projectId, platformId, createdAt])
}

model PlatformPublishMetric {
  id             String   @id @default(cuid())
  projectId      String
  platformId     String
  platformName   String
  views          Int      @default(0)
  clicks         Int      @default(0)
  favorites      Int      @default(0)
  follows        Int      @default(0)
  comments       Int      @default(0)
  paidReads      Int      @default(0)
  editorFeedback String   @default("")
  contractStatus String   @default("unknown")
  publishUrl     String   @default("")
  notes          String   @default("")
  snapshotDate   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, platformId, snapshotDate])
}

model PlatformKnowledgeFeedbackReceipt {
  id                 String   @id @default(cuid())
  receiptId          String   @unique
  projectId          String
  platformId         String
  platformName       String
  actionLabel        String
  title              String
  message            String
  completedStepLabel String
  stopReason         String
  nextAction         String
  href               String
  severity           String
  createdAt          DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([projectId, platformId, createdAt])
}

model GateActionAudit {
  id              String   @id @default(cuid())
  receiptId       String   @unique
  actionId        String
  projectId       String?
  platformId      String   @default("")
  platformName    String   @default("")
  label           String
  detail          String
  href            String
  status          String
  message         String
  executionType   String
  succeededCount  Int      @default(0)
  failedCount     Int      @default(0)
  taskId          String?
  recheckStatus   String
  recheckLabel    String
  recheckDetail   String
  recheckAction   String
  payload         String   @default("{}")
  createdAt       DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([platformId, createdAt])
  @@index([executionType, createdAt])
}

model GateDispatchTask {
  id                 String   @id @default(cuid())
  dispatchKey        String   @unique
  projectId          String?
  platformId         String
  platformName       String
  stage              String
  state              String   @default("queued")
  priorityScore      Int      @default(0)
  ownerRole          String
  title              String
  detail             String
  dueLabel           String
  actionLabel        String
  href               String
  acceptanceCriteria String   @default("[]")
  evidence           String   @default("[]")
  sourceReceiptId    String?
  completionEvidence String   @default("")
  reviewLatestAt     DateTime
  assignedAt         DateTime?
  completedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([state, priorityScore])
  @@index([platformId, updatedAt])
  @@index([projectId, updatedAt])
}
